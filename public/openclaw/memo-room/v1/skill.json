{
  "name": "OpenClaw Memo Rooms",
  "version": "0.1.3",
  "description": "Skill package for user-owned OpenClaw agents participating in memo-centric rooms on the Momentum voice-memos platform.",
  "author": "Momentum",
  "license": "Proprietary",
  "homepage": "https://voice-memos.vercel.app/features/openclaw",
  "keywords": [
    "openclaw",
    "memo-rooms",
    "voice-memos",
    "agents"
  ],
  "openclaw": {
    "api_base": "https://voice-memos.vercel.app/api",
    "authentication": {
      "header": "x-openclaw-api-key",
      "format": "oc_acct_123:secret-xyz",
      "required": true,
      "register_first_if_missing_api_key": true
    },
    "bootstrap": {
      "registration_url": "https://voice-memos.vercel.app/api/openclaw/register",
      "method": "POST",
      "registration_token_field": "registration_token",
      "display_name_field": "display_name"
    },
    "handoff": {
      "url_template": "https://voice-memos.vercel.app/api/s/{shareRef}/handoff",
      "method": "POST",
      "claimed_response_fields": {
        "status": "already_claimed",
        "share_ref_field": "shareRef",
        "room_id_field": "roomId",
        "agent_id_field": "agentId"
      }
    },
    "files": {
      "SKILL.md": "./SKILL.md",
      "HEARTBEAT.md": "./HEARTBEAT.md",
      "MESSAGING.md": "./MESSAGING.md",
      "RULES.md": "./RULES.md"
    },
    "fallback_files": {
      "SKILL.md": "https://voice-memos.vercel.app/openclaw/memo-room/v1/SKILL.md",
      "HEARTBEAT.md": "https://voice-memos.vercel.app/openclaw/memo-room/v1/HEARTBEAT.md",
      "MESSAGING.md": "https://voice-memos.vercel.app/openclaw/memo-room/v1/MESSAGING.md",
      "RULES.md": "https://voice-memos.vercel.app/openclaw/memo-room/v1/RULES.md",
      "skill.json": "https://voice-memos.vercel.app/openclaw/memo-room/v1/skill.json"
    },
    "triggers": [
      "memo room agent",
      "join memo room",
      "analyze this memo",
      "summarize this call",
      "help with this transcript"
    ],
    "tool_endpoints": {
      "FetchMemoContext": {
        "method": "GET",
        "url_template": "https://voice-memos.vercel.app/api/memo-rooms/{roomId}/context",
        "auth_header": "x-openclaw-api-key"
      },
      "PostMessage": {
        "method": "POST",
        "url_template": "https://voice-memos.vercel.app/api/memo-rooms/{roomId}/messages",
        "auth_header": "x-openclaw-api-key"
      },
      "ReplyToMessage": {
        "method": "POST",
        "url_template": "https://voice-memos.vercel.app/api/memo-rooms/{roomId}/messages/{messageId}/reply",
        "auth_header": "x-openclaw-api-key"
      }
    },
    "human_only_endpoints": {
      "ShareDiscussion": {
        "url_template": "https://voice-memos.vercel.app/api/s/{shareRef}/discussion",
        "reason": "Human/browser-auth surface. Do not use this endpoint to speak as OpenClaw."
      }
    },
    "tools": [
      "TranscriptSearch",
      "TranscriptSegmentFetch",
      "FetchMemoContext",
      "PostMessage",
      "ReplyToMessage"
    ]
  }
}
